{
  "name": "@kikiutils/eslint-config",
  "type": "module",
  "version": "9.0.0",
  "description": "Using antfu/eslint-config as a base for eslint-config, slightly modified the settings and added additional plugins, mainly for my own use.",
  "author": "kiki-kanri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kikiutils/eslint-config.git"
  },
  "keywords": [],
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    "./*": "./dist/*.js"
  },
  "files": [
    "./dist",
    "./src"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsdown",
    "bumplog": "changelogen --bump --hideAuthorEmail",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix --max-warnings 0",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && changelogen --hideAuthorEmail --push --release && npm publish",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "typecheck": "tsc -b --noEmit"
  },
  "peerDependencies": {
    "@eslint/css": "^1.1.0",
    "@html-eslint/parser": "^0.59.0",
    "eslint": ">= 9.0.0",
    "eslint-plugin-better-tailwindcss": "^4.4.0",
    "eslint-plugin-format": ">= 1.0.0",
    "tailwind-csstree": "^0.3.1",
    "tailwindcss": ">= 3.0.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "peerDependenciesMeta": {
    "@eslint/css": {
      "optional": true
    },
    "@html-eslint/parser": {
      "optional": true
    },
    "eslint": {
      "optional": true
    },
    "eslint-plugin-better-tailwindcss": {
      "optional": true
    },
    "eslint-plugin-format": {
      "optional": true
    },
    "tailwind-csstree": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "eslint-plugin-promise": "^7.2.1"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@html-eslint/parser": "^0.59.0",
    "@kikiutils/tsconfigs": "^6.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "changelogen": "^0.6.2",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-format": "^2.0.1",
    "knip": "^6.4.1",
    "publint": "^0.3.18",
    "tailwind-csstree": "^0.3.1",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "unplugin-unused": "^0.5.7",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
